# ------------------------------------------------------------------
# 3. Prompt builder – turns the registry into instructions the LLM
#    can follow, and into a JSON schema for validation.
# ------------------------------------------------------------------
def build_tool_system_prompt() -> str:
    tool_lines = []
    for name, spec in TOOL_REGISTRY.items():
        params = spec["parameters"]
        if params:
            param_desc = ", ".join(
                f'{p}({"required" if pv.get("required") else "optional"}, {pv["type"]}): {pv.get("description", "")}'
                for p, pv in params.items()
            )
        else:
            param_desc = "no parameters"
        tool_lines.append(f'- "{name}": {spec["description"]} [{param_desc}]')
    tools_block = "\n".join(tool_lines)

    return f"""You are ISHA's intent router. Decide if the user's message requires
calling one of the tools below, or if it is just a normal conversational message.

Available tools:
{tools_block}

Respond with ONLY a single JSON object, no other text, no markdown fences, in this exact shape:
{{"action": "tool_call", "tool": "<tool_name>", "arguments": {{...}}}}
or, if no tool applies:
{{"action": "chat_reply", "tool": null, "arguments": {{}}}}

Rules:
- Only use a tool name from the list above, spelled exactly as shown.
- Only include arguments that are defined for that tool.
- If required arguments are missing from the user's message, use action "chat_reply" instead
  and ask the user for the missing detail in natural conversation.
- Never invent a tool name that isn't listed.
- Output must be valid JSON and nothing else."""


# ------------------------------------------------------------------
# 3b. Cheap local pre-filter for the intent router.
#     Before this, EVERY message paid for two sequential model calls
#     (JSON-mode intent router, then the real chat reply) -- double the
#     latency of a plain `ollama run` test for every single message, tool
#     or not. Most messages are just conversation, so only bother asking
#     the model to route intent when the text plausibly names a tool.
#     The router LLM call still does the real parsing/argument-extraction;
#     this only decides whether to make that call at all.
# ------------------------------------------------------------------
_TOOL_KEYWORDS = [
    "notepad", "calculator", "calc", "browser", "chrome", "edge", "internet",
    "task manager", "taskmgr", "mute", "unmute", "volume", "awaaz",
    "cpu", "ram", "memory", "battery", "charge", "charging",
    "time", "samay", "baje", "date", "tareekh", "aaj",
    "lock", "minimize", "maximize", "close", "band kar", "band karo",
    "switch window", "url", "http", "www", ".com", ".in", "website", "tab",
    "folder", "desktop pe", "search file", "find file", "dhund",
    "stats", "system status", "khol", "open ", "open,",
]

def _looks_like_command(text: str) -> bool:
    t = (text or "").lower()
    return any(k in t for k in _TOOL_KEYWORDS)


# ------------------------------------------------------------------
# 4. Safe JSON extraction from raw LLM text
# ------------------------------------------------------------------
def parse_router_json(raw_text: str):
    """Best-effort, defensive extraction of the router's JSON object.
    Returns a dict or None if nothing parseable was found."""
    if not raw_text:
        return None
    text = raw_text.strip()
    # Strip common markdown fences some models add despite instructions
    if text.startswith("```"):
        text = text.strip("`")
        if text.lower().startswith("json"):
            text = text[4:]
        text = text.strip()
    try:
        return json.loads(text)
    except Exception:
        pass
    # Fallback: find the first balanced {...} block and try that
    decoder = json.JSONDecoder()
    start = text.find("{")
    while start != -1:
        try:
            obj, _ = decoder.raw_decode(text, start)
            return obj
        except Exception:
            start = text.find("{", start + 1)
    return None


# ------------------------------------------------------------------
# 5. Validation + execution — the only place a tool actually runs
# ------------------------------------------------------------------
class ToolError(Exception):
    pass


def _validate_args(name: str, schema: dict, raw_args) -> dict:
    if raw_args is None:
        raw_args = {}
    if not isinstance(raw_args, dict):
        raise ToolError(f"'{name}' arguments must be a JSON object.")

    clean = {}
    for pname, pspec in schema.items():
        if pname in raw_args:
            value = raw_args[pname]
            ptype = pspec["type"]
            if ptype == "integer":
                try:
                    value = int(value)
                except Exception:
                    raise ToolError(f"'{pname}' must be an integer.")
            elif ptype == "boolean":
                if isinstance(value, str):
                    value = value.strip().lower() in ("true", "1", "yes")
                value = bool(value)
            elif ptype == "string":
                value = str(value)
            clean[pname] = value
        elif pspec.get("required"):
            raise ToolError(f"Missing required argument '{pname}' for tool '{name}'.")

    # Reject any argument the LLM invented that isn't in the schema —
    # this is the key security boundary: unknown keys never reach the handler.
    unknown = set(raw_args) - set(schema)
    if unknown:
        raise ToolError(f"Unknown argument(s) for '{name}': {', '.join(unknown)}")

    return clean


def execute_tool(name: str, raw_args) -> str:
    """The single, secure entry point for running a tool.
    - `name` must exactly match a registered tool (allow-list).
    - `raw_args` is validated field-by-field against that tool's schema.
    - Never eval()/exec()s anything, never shells out with an LLM-built string.
    Raises ToolError on any problem; caller decides how to surface it.
    """
    if name not in TOOL_REGISTRY:
        raise ToolError(f"Unknown tool '{name}'.")
    spec = TOOL_REGISTRY[name]
    clean_args = _validate_args(name, spec["parameters"], raw_args)
    try:
        return spec["handler"](clean_args)
    except ToolError:
        raise
    except Exception as e:
        raise ToolError(f"Tool '{name}' failed: {e}")


