# System audio control (mute / volume)
# Uses pycaw for real, absolute volume control when available
# (pip install pycaw comtypes). Always falls back to the Windows
# media-mute key so the Mute button works even without pycaw.
try:
    from ctypes import cast, POINTER
    from comtypes import CLSCTX_ALL
    from pycaw.pycaw import AudioUtilities, IAudioEndpointVolume
    _PYCAW_OK = True
except Exception:
    _PYCAW_OK = False

def _get_volume_interface():
    devices = AudioUtilities.GetSpeakers()
    interface = devices.Activate(IAudioEndpointVolume._iid_, CLSCTX_ALL, None)
    return cast(interface, POINTER(IAudioEndpointVolume))

def set_system_mute(muted: bool) -> None:
    if _PYCAW_OK:
        try:
            _get_volume_interface().SetMute(1 if muted else 0, None)
            return
        except Exception as e:
            print(f"[Mute] pycaw failed, falling back: {e}")
    try:
        VK_VOLUME_MUTE = 0xAD
        user32 = ctypes.windll.user32
        user32.keybd_event(VK_VOLUME_MUTE, 0, 0, 0)
        user32.keybd_event(VK_VOLUME_MUTE, 0, 2, 0)
    except Exception as e:
        print(f"[STUB] mute={muted}  (Windows-only feature: {e})")

VK_VOLUME_DOWN = 0xAE
VK_VOLUME_UP   = 0xAF

def _press_volume_key(vk_code: int, times: int = 1) -> None:
    user32 = ctypes.windll.user32
    for _ in range(times):
        user32.keybd_event(vk_code, 0, 0, 0)   # key down
        user32.keybd_event(vk_code, 0, 2, 0)   # key up

def set_system_volume(percent: int, previous_percent: int = None) -> None:
    """Move the LIVE system volume toward `percent`.
    Uses pycaw for an exact set if installed; otherwise nudges the
    real Windows volume up/down (like pressing the volume keys) based
    on how far the slider moved — this works with no extra installs."""
    percent = max(0, min(100, percent))

    if _PYCAW_OK:
        try:
            _get_volume_interface().SetMasterVolumeLevelScalar(percent / 100.0, None)
            return
        except Exception as e:
            print(f"[Volume] pycaw failed, falling back to key-based control: {e}")

    try:
        if previous_percent is None:
            previous_percent = percent
        delta = percent - previous_percent
        STEP = 2  # Windows moves ~2% per volume-key press by default
        presses = round(abs(delta) / STEP)
        if presses > 0:
            vk = VK_VOLUME_UP if delta > 0 else VK_VOLUME_DOWN
            _press_volume_key(vk, presses)
    except Exception as e:
        print(f"[STUB] set system volume -> {percent}%  (Windows-only feature: {e})")

def open_task_manager() -> None:
    """Try several ways to launch Task Manager so it works on any Windows setup."""
    errors = []
    try:
        os.startfile("taskmgr.exe")
        return
    except Exception as e:
        errors.append(str(e))
    try:
        subprocess.Popen("taskmgr.exe", shell=True)
        return
    except Exception as e:
        errors.append(str(e))
    try:
        windir = os.environ.get("WINDIR", r"C:\Windows")
        subprocess.Popen(os.path.join(windir, "System32", "taskmgr.exe"))
        return
    except Exception as e:
        errors.append(str(e))
    print(f"[Task Manager] Could not open Task Manager. Tried: {' | '.join(errors)}")

