class HandGestureWorker(QThread):
    # (action_name, payload) — main-thread slot decides what to do with it.
    # action_name in {"volume_set", "mute_toggle", "scroll"}
    gesture_action = pyqtSignal(str, dict)
    frame_ready    = pyqtSignal(QImage)   # optional live preview (only if emit_preview=True)
    status_changed = pyqtSignal(str)
    error_occurred = pyqtSignal(str)

    # ---- tunables ----
    VOLUME_TOP_Y        = 0.15   # normalized hand-y treated as 100% volume
    VOLUME_BOTTOM_Y      = 0.85   # normalized hand-y treated as 0% volume
    VOLUME_MIN_DELTA     = 2      # only emit a new volume if it changed by this much (%)
    MUTE_COOLDOWN_SEC    = 1.2    # minimum gap between fist-triggered mute toggles
    SCROLL_JITTER_GUARD  = 0.008  # ignore vertical moves smaller than this (normalized)
    FRAME_DELAY_MS       = 40     # ~25 fps cap — plenty for gestures, keeps CPU low

    def __init__(self, camera_index: int = 0, emit_preview: bool = True, parent=None):
        super().__init__(parent)
        self.camera_index = camera_index
        self.emit_preview = emit_preview
        self._running = False
        # per-run gesture state (reset in run())
        self._last_mute_time = 0.0
        self._mute_armed = True
        self._last_emitted_volume = None
        self._scroll_prev_y = None

    def stop(self):
        self._running = False

    # ------------------------------------------------------------
    def run(self):
        if not _CV2_OK:
            self.error_occurred.emit("OpenCV missing. Install: pip install opencv-python")
            return
        if not _MEDIAPIPE_OK:
            self.error_occurred.emit(
                "MediaPipe not usable: " + (_MEDIAPIPE_ERROR or "install with 'pip install mediapipe'")
            )
            return

        cap = None
        hands = None
        try:
            cap = cv2.VideoCapture(self.camera_index, cv2.CAP_DSHOW)
            if not cap.isOpened():
                self.error_occurred.emit("Webcam open nahi ho paaya (index/permissions check karo).")
                return

            mp_hands = mp.solutions.hands
            hands = mp_hands.Hands(
                model_complexity=0,          # lightest model — real-time on CPU
                max_num_hands=1,
                min_detection_confidence=0.6,
                min_tracking_confidence=0.5,
            )
            mp_draw = mp.solutions.drawing_utils

            # reset state for this session
            self._last_mute_time = 0.0
            self._mute_armed = True
            self._last_emitted_volume = None
            self._scroll_prev_y = None

            self._running = True
            self.status_changed.emit("Hand control active.")
            while self._running:
                ok, frame = cap.read()
                if not ok:
                    self.msleep(self.FRAME_DELAY_MS)
                    continue

                frame = cv2.flip(frame, 1)  # mirror, feels natural to the user
                rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
                results = hands.process(rgb)

                if results.multi_hand_landmarks:
                    landmarks = results.multi_hand_landmarks[0]
                    if self.emit_preview:
                        mp_draw.draw_landmarks(frame, landmarks, mp_hands.HAND_CONNECTIONS)
                    self._interpret_gesture(landmarks.landmark)
                else:
                    self._scroll_prev_y = None
                    self._mute_armed = True

                if self.emit_preview:
                    self._emit_frame(frame)

                self.msleep(self.FRAME_DELAY_MS)
        except Exception as e:
            self.error_occurred.emit(f"Hand control error: {e}")
        finally:
            if cap is not None:
                cap.release()
            if hands is not None:
                hands.close()
            self.status_changed.emit("Hand control stopped.")

    # ------------------------------------------------------------
    def _emit_frame(self, bgr_frame):
        rgb = cv2.cvtColor(bgr_frame, cv2.COLOR_BGR2RGB)
        h, w, ch = rgb.shape
        qimg = QImage(rgb.data, w, h, ch * w, QImage.Format_RGB888)
        # .copy() detaches from the numpy buffer, which is reused next loop
        self.frame_ready.emit(qimg.copy())

    def _extended_fingers(self, lm) -> int:
        """Counts extended fingers among index/middle/ring/pinky only
        (thumb skipped — its extended/curled test depends on handedness
        and is unreliable enough to just leave out of a simple gesture set)."""
        tip_pip_pairs = [(8, 6), (12, 10), (16, 14), (20, 18)]
        return sum(1 for tip, pip in tip_pip_pairs if lm[tip].y < lm[pip].y)

    def _interpret_gesture(self, lm):
        extended = self._extended_fingers(lm)
        hand_y = lm[0].y  # wrist, normalized 0 (top of frame) .. 1 (bottom)

        if extended >= 4:
            # Open palm -> map vertical hand position straight to volume %
            self._scroll_prev_y = None
            self._mute_armed = True
            pct = self._y_to_volume_percent(hand_y)
            if self._last_emitted_volume is None or abs(pct - self._last_emitted_volume) >= self.VOLUME_MIN_DELTA:
                self._last_emitted_volume = pct
                self.gesture_action.emit("volume_set", {"percent": pct})

        elif extended == 0:
            # Fist -> mute toggle, debounced so holding the pose doesn't spam it
            now = time.time()
            if self._mute_armed and (now - self._last_mute_time) > self.MUTE_COOLDOWN_SEC:
                self._last_mute_time = now
                self._mute_armed = False
                self.gesture_action.emit("mute_toggle", {})

        elif extended == 2:
            # Index + middle -> scroll, direction from frame-to-frame vertical movement
            self._mute_armed = True
            if self._scroll_prev_y is not None:
                delta = hand_y - self._scroll_prev_y
                if abs(delta) > self.SCROLL_JITTER_GUARD:
                    direction = "down" if delta > 0 else "up"
                    self.gesture_action.emit("scroll", {"direction": direction})
            self._scroll_prev_y = hand_y

        else:
            self._scroll_prev_y = None
            self._mute_armed = True

    def _y_to_volume_percent(self, y: float) -> int:
        y = max(self.VOLUME_TOP_Y, min(self.VOLUME_BOTTOM_Y, y))
        span = self.VOLUME_BOTTOM_Y - self.VOLUME_TOP_Y
        pct = 100 * (1 - (y - self.VOLUME_TOP_Y) / span)
        return int(max(0, min(100, round(pct))))


