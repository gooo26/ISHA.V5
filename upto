        """Runs on the UI thread (Qt queues cross-thread signals automatically).
        This is the ONLY place gesture output turns into real OS changes —
        the worker thread itself never touches pycaw/win32 directly."""
        if action == "volume_set":
            pct = int(payload.get("percent", 0))
            prev = self._hand_last_volume if self._hand_last_volume is not None else pct
            set_system_volume(pct, prev)
            self._hand_last_volume = pct
            if self._qs_popup and self._qs_popup.isVisible():
                self._qs_popup._vol.blockSignals(True)
                self._qs_popup._vol.setValue(pct)
                self._qs_popup._vol.blockSignals(False)
                self._qs_popup._last_vol = pct

        elif action == "mute_toggle":
            self._hand_muted = not self._hand_muted
            set_system_mute(self._hand_muted)
            self.respond("Muted (gesture)." if self._hand_muted else "Unmuted (gesture).", "isha")
            if self._qs_popup and self._qs_popup.isVisible():
                self._qs_popup._t_mute.set_on(self._hand_muted)

        elif action == "scroll":
            if self.os_controller is not None:
                self.os_controller.scroll(payload.get("direction", "up"))

