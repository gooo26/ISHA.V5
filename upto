# Background worker: Edge-TTS speech synthesis + playback (female neural voice)
class TTSWorker(QThread):
    finished_speaking = pyqtSignal()
    error_occurred    = pyqtSignal(str)

    def __init__(self, text: str, voice: str = "en-US-AriaNeural",
                 rate: str = "+0%", parent=None):
        super().__init__(parent)
        self.text  = text
        self.voice = voice
        self.rate  = rate

    def run(self):
        if not _TTS_OK:
            self.error_occurred.emit("edge-tts / pygame missing. Install: pip install edge-tts pygame")
            self.finished_speaking.emit()
            return
        out_path = os.path.join(tempfile.gettempdir(), f"isha_tts_{int(time.time()*1000)}.mp3")
        try:
            asyncio.run(self._synth(out_path))
            self._play(out_path)
        except Exception as e:
            self.error_occurred.emit(str(e))
        finally:
            try:
                if os.path.exists(out_path):
                    os.remove(out_path)
            except Exception:
                pass
            self.finished_speaking.emit()

    async def _synth(self, out_path: str):
        communicate = edge_tts.Communicate(self.text, voice=self.voice, rate=self.rate)
        await communicate.save(out_path)

    def _play(self, path: str):
        pygame.mixer.init()
        try:
            pygame.mixer.music.load(path)
            pygame.mixer.music.play()
            while pygame.mixer.music.get_busy():
                time.sleep(0.1)
        finally:
            pygame.mixer.quit()


