# Background worker: talks to the local Ollama model over HTTP (/api/chat)
class OllamaWorker(QThread):
    chunk_received = pyqtSignal(str)   # cumulative text so far (streaming mode)
    finished_reply  = pyqtSignal(str)   # final full text
    error_occurred  = pyqtSignal(str)

    def __init__(self, host: str, model: str, messages: list, options: dict,
                 streaming: bool = True, json_mode: bool = False,
                 thinking: bool = False, keep_alive: str = "30m", parent=None):
        super().__init__(parent)
        self.host      = host.rstrip("/")
        self.model     = model
        self.messages  = messages
        self.options   = options
        self.streaming = streaming
        self.json_mode = json_mode
        self.thinking  = thinking
        self.keep_alive = keep_alive
        self._stop     = False

    def stop(self):
        self._stop = True

    def run(self):
        if not _REQUESTS_OK:
            self.error_occurred.emit("'requests' library missing. Install: pip install requests")
            return
        url = f"{self.host}/api/chat"
        payload = {
            "model":    self.model,
            "messages": self.messages,
            "stream":   self.streaming,
            "options":  self.options,
        }
        if self.keep_alive:
            payload["keep_alive"] = self.keep_alive
        if self.json_mode:
            payload["format"] = "json"
        if self.thinking:
            payload["think"] = True
        try:
            if self.streaming:
                full = ""
                with requests.post(url, json=payload, stream=True, timeout=(10, 300)) as r:
                    if r.status_code != 200:
                        self.error_occurred.emit(f"Ollama error {r.status_code}: {r.text[:200]}")
                        return
                    for raw_line in r.iter_lines():
                        if self._stop:
                            break
                        if not raw_line:
                            continue
                        try:
                            data = json.loads(raw_line.decode("utf-8"))
                        except Exception:
                            continue
                        piece = (data.get("message") or {}).get("content", "")
                        if piece:
                            full += piece
                            self.chunk_received.emit(full)
                        if data.get("done"):
                            break
                self.finished_reply.emit(full)
            else:
                r = requests.post(url, json=payload, timeout=(10, 300))
                if r.status_code != 200:
                    self.error_occurred.emit(f"Ollama error {r.status_code}: {r.text[:200]}")
                    return
                data = r.json()
                text = (data.get("message") or {}).get("content", "")
                self.finished_reply.emit(text)
        except requests.exceptions.ConnectionError:
            self.error_occurred.emit(
                f"Ollama se connect nahi ho paaya. Check karo 'ollama serve' chal raha hai "
                f"aur '{self.model}' pulled hai (ollama pull {self.model}).")
        except Exception as e:
            self.error_occurred.emit(f"LLM error: {e}")


# ------------------------------------------------
# Background worker: runs once at startup. Confirms the configured model is
# actually pulled in Ollama (a stale/mismatched model name in the config file
# is a classic reason ISHA answers "wrong"/differently than a manual
# `ollama run <model>` test in cmd) and preloads it into memory so the very
# first real chat message doesn't pay a slow cold-start load penalty.
class OllamaWarmupWorker(QThread):
    model_missing = pyqtSignal(list)   # emitted with the list of models Ollama actually has
    warmed_up     = pyqtSignal()

    def __init__(self, host: str, model: str, keep_alive: str = "30m", parent=None):
        super().__init__(parent)
        self.host = host.rstrip("/")
        self.model = model
        self.keep_alive = keep_alive

    def run(self):
        if not _REQUESTS_OK:
            return
        try:
            r = requests.get(f"{self.host}/api/tags", timeout=5)
            names = [m.get("name", "") for m in r.json().get("models", [])]
        except Exception:
            return   # Ollama not reachable yet -- the normal chat flow will
                      # surface a clear connection error on the first message.
        base = self.model.split(":")[0]
        if self.model not in names and not any(n.split(":")[0] == base for n in names):
            self.model_missing.emit(names)
            return
        try:
            # An empty prompt to /api/generate loads the model without
            # generating any text -- this is Ollama's documented warm-up call.
            requests.post(f"{self.host}/api/generate",
                           json={"model": self.model, "keep_alive": self.keep_alive},
                           timeout=180)
        except Exception:
            pass
        self.warmed_up.emit()


