TOOL_REGISTRY: dict = {}


def tool(name: str, description: str, parameters: dict = None):
    """Decorator that registers a function as an LLM-callable tool."""
    def _wrap(func):
        TOOL_REGISTRY[name] = {
            "description": description,
            "parameters": parameters or {},
            "handler": func,
        }
        return func
    return _wrap


